{
  "id": "influencer-partnerships",
  "name": "Influencer & Creator Partnerships",
  "category": "partnerships",
  "applies_when": {
    "company_stage": ["early", "growth", "relaunch"],
    "channels_includes": ["youtube", "twitter", "linkedin", "instagram", "tiktok", "podcast"],
    "business_model": ["saas", "info_product", "mobile_app", "ecommerce", "marketplace"]
  },
  "do_not_use_when": {
    "company_stage": ["pre-launch", "enterprise_field_sales_only"],
    "constraints_includes": ["no_budget_for_partnerships", "product_not_demo_ready", "regulated_no_third_party_endorsement"]
  },
  "required_inputs": [
    "product_name",
    "main_value_proposition",
    "target_audience",
    "partnership_budget",
    "existing_proof",
    "available_assets"
  ],
  "output_schema": "marketing_decision",
  "primary_metric": "influencer_cpa_qualified_signup",
  "playbook_selector": [
    { "if": { "current_users_lt": 100 }, "pick": "no-audience" },
    { "if": { "business_model": ["saas"] }, "pick": "b2b-saas" }
  ]
}
