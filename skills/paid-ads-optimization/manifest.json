{
  "id": "paid-ads-optimization",
  "name": "Paid Ads Optimization",
  "category": "paid",
  "applies_when": {
    "company_stage": ["early", "growth", "relaunch"],
    "channels_includes": ["google_ads", "meta_ads", "linkedin_ads", "twitter_ads"],
    "business_model": ["saas", "ecommerce", "mobile_app", "marketplace", "info_product"]
  },
  "do_not_use_when": {
    "company_stage": ["pre-launch", "enterprise_field_sales_only"],
    "constraints_includes": ["no_paid_budget", "landing_page_not_ready", "no_conversion_tracking", "cac_must_be_zero"]
  },
  "required_inputs": [
    "product_name",
    "main_value_proposition",
    "target_audience",
    "monthly_ad_budget",
    "existing_proof",
    "available_assets"
  ],
  "output_schema": "marketing_decision",
  "primary_metric": "paid_cpa_qualified_conversion",
  "playbook_selector": [
    { "if": { "current_users_lt": 100 }, "pick": "no-audience" },
    { "if": { "business_model": ["saas"] }, "pick": "b2b-saas" }
  ]
}
