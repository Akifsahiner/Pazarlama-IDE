# Marketing IDE — production server environment (placeholders only)
# Copy to server/.env and fill in real values. Never commit server/.env.

PORT=8787
HOST=0.0.0.0
CORS_ORIGINS=https://marketingide.app,https://www.marketingide.app

# Auth — required for hosted mode
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Never enable in production
DEV_NO_AUTH=

# LLM providers (server-side only — users never paste keys in desktop)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Billing — Paddle (production default)
BILLING_PROVIDER=paddle
BILLING_SUCCESS_URL=marketingide://billing/success
BILLING_CANCEL_URL=marketingide://billing/cancel
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox
PADDLE_PRICE_PRO=pri_...
PADDLE_PRICE_TEAM=pri_...

# Billing — Stripe (legacy fallback)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
