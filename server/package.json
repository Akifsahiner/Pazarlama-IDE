{
  "name": "marketing-ide-server",
  "version": "0.1.0",
  "description": "Marketing IDE — backend proxy (LLM + agent)",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import tsx --test src/tier/tiers.test.ts src/billing/pricing.test.ts src/brain/marketingStrategyRoute.test.ts src/brain/answerCritic.test.ts src/brain/executionClassifier.test.ts",
    "eval:gtm": "npm run build && node evals/gtm-golden.mjs && node evals/gtm-behavioral.mjs",
    "eval:skill-coverage": "npm run build && node evals/skill-coverage.mjs",
    "skill:audit": "node scripts/skill-audit.mjs",
    "skill:scaffold": "node scripts/skill-scaffold.mjs",
    "eval:skills": "npm run eval:skill-coverage && npm run skill:audit",
    "eval:skill-quality-ph": "npm run build && node evals/skill-quality-ph.mjs",
    "eval:skill-quality": "npm run build && node evals/skill-quality.mjs",
    "eval:p0-plan-smoke": "npm run build && node evals/p0-plan-smoke.mjs",
    "eval:devflow-plan-smoke": "npm run build && node evals/devflow-plan-smoke.mjs",
    "eval:thesis-quality": "node --import tsx evals/thesis-quality-matrix.mjs",
    "eval:task-contract": "node --import tsx evals/task-contract-matrix.mjs",
    "eval:execution-kernel": "node --import tsx evals/execution-kernel-matrix.mjs",
    "eval:first-hour-thesis": "node --import tsx evals/first-hour-thesis.mjs",
    "browser:install": "playwright install chromium"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@fastify/websocket": "^11.2.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "openai": "^6.44.0",
    "playwright": "^1.61.1",
    "stripe": "^18.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
